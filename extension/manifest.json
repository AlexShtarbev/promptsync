{
  "manifest_version": 3,
  "name": "PromptSync",
  "version": "0.2.0",
  "description": "Inject storyboard prompts into MJ, OpenArt, and Google Flow",
  "permissions": ["activeTab", "tabs", "storage", "clipboardWrite", "sidePanel"],
  "host_permissions": [
    "http://localhost:3456/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.midjourney.com/*", "https://midjourney.com/*"],
      "js": ["content/shared.js", "content/midjourney.js"]
    },
    {
      "matches": ["https://openart.ai/*"],
      "js": ["content/shared.js", "content/create-image-characters.js", "content/visual-references-react.js", "content/openart.js"]
    },
    {
      "matches": ["https://openart.ai/*"],
      "js": ["content/openart-page.js"],
      "world": "MAIN"
    },
    {
      "matches": ["https://labs.google/*"],
      "js": ["content/shared.js", "content/googleflow.js"]
    },
    {
      "matches": ["https://labs.google/*"],
      "js": ["content/googleflow-page.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "commands": {
    "inject-next": {
      "suggested_key": {
        "default": "Ctrl+Shift+Right"
      },
      "description": "Inject the next shot prompt"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
